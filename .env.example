# map-service-infra — .env 템플릿. 실제 값은 `.env`에 채우고 절대 commit 하지 않는다.

# (1) PostgreSQL
POSTGRES_DB=map
POSTGRES_USER=map
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# (2) Redis (단일 인스턴스, DB 번호로 용도 분리 — def §5.2)
# DB0=세션 / DB1=JWT 블랙리스트 / DB2=편집 세션 / DB3=rate-limit + Mode1 카운터 + Streams / DB4=hub 캐시
REDIS_HOST=redis
REDIS_PORT=6379

# (3) 내부 서비스 인증·라우팅 (D1 — info → hub 통일)
INTERNAL_SERVICE_TOKEN=replace-with-32-chars-or-more
AGENT_HOST=agent
AGENT_BASE_URL=http://agent:8000
HUB_HOST=hub
HUB_BASE_URL=http://hub:8000
USER_HOST=user
USER_BASE_URL=http://user:8080

# (4) JWT (user 전용, HS256)
JWT_SECRET=replace-with-32-chars-or-more
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# (5) 외부 API 키
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_REDIRECT_URI=
KAKAO_REST_API_KEY=
KAKAO_MAPS_JS_KEY=
KMA_SERVICE_KEY=
TOUR_API_SERVICE_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# (6) OSRM 빌드 옵션 (선택 — 빌드 시간 단축용 sub-region bbox)
OSRM_BBOX=

# (7) 모드·메타
LANGGRAPH_SCHEMA=langgraph
DEMO_FORCE_CACHE=false

# (8) admin 운영 모니터링 (cut 1: 읽기전용)
# MAP_ADMIN_PASSWORD 는 db/init/10-admin.sh 의 map_admin 역할 비밀번호이며,
# ADMIN_DATABASE_URL 의 비밀번호와 반드시 동일해야 한다(단일 출처).
MAP_ADMIN_PASSWORD=replace-with-map-admin-password
ADMIN_DATABASE_URL=postgresql+psycopg://map_admin:replace-with-map-admin-password@postgres:5432/map
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASSWORD=replace-with-strong-password
